<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../components/head') %>
    <link rel="stylesheet" href="/questionList.css" />
    <link rel="stylesheet" href="/shared.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <title>Users</title>
  </head>
  <body>
    <%- include('../components/header') %>
    <main style="min-width: 55rem">
      <h1>Users Management</h1>
      
      <div style="margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center;">
        <form method="GET" action="/users" id="searchForm" style="flex: 1; margin-right: 20px; display: flex; align-items: center;">
          <input 
            type="text" 
            name="search" 
            id="searchInput"
            placeholder="Search by name or email..." 
            value="<%= search %>"
            style="padding: 8px; width: 100%; max-width: 400px; border: 1px solid #ccc; border-radius: 4px;"
          />
          <button type="submit" style="padding: 8px 16px; margin-left: 10px;">Search</button>
        </form>
        <a href="/users/add" style="padding: 10px 20px; background-color: rgb(189, 130, 41);; color: white; text-decoration: none; border-radius: 4px;">
          Add User
        </a>
      </div>

      <% if (users.length === 0) { %>
        <p>No users found.</p>
      <% } else { %>
        <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
          <thead>
            <tr style="background-color: #f5f5f5;">
              <th style="padding: 12px; text-align: left; border-bottom: 2px solid #ddd; width: 5%;">ID</th>
              <th style="padding: 12px; text-align: left; border-bottom: 2px solid #ddd; width: 20%;">Name</th>
              <th style="padding: 12px; text-align: left; border-bottom: 2px solid #ddd; width: 35%;">Email</th>
              <th style="padding: 12px; text-align: left; border-bottom: 2px solid #ddd; width: 10%;">Admin</th>
              <th style="padding: 12px; text-align: center; border-bottom: 2px solid #ddd; width: 20%;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(user => { %>
              <tr>
                <td style="padding: 12px; border-bottom: 1px solid #ddd;"><%= user.user_id %></td>
                <td style="padding: 12px; border-bottom: 1px solid #ddd;"><%= user.name %></td>
                <td style="padding: 12px; border-bottom: 1px solid #ddd;"><%= user.email %></td>
                <td style="padding: 12px; border-bottom: 1px solid #ddd;">
                  <%= user.isAdmin === 1 ? 'Yes' : 'No' %>
                </td>
                <td style="padding: 12px; border-bottom: 1px solid #ddd; text-align: center;">
                  <a 
                    href="/users/edit/<%= user.user_id %>"
                    style="background: none; border: none; color: #007bff; cursor: pointer; margin-right: 10px; font-size: 18px; text-decoration: none;"
                  >
                    <i class="fas fa-edit"></i>
                  </a>
                  <button 
                    class="delete-btn" 
                    data-id="<%= user.user_id %>"
                    data-name="<%= user.name %>"
                    style="background: none; border: none; color: #dc3545; cursor: pointer; font-size: 18px;"
                  >
                    <i class="fas fa-trash"></i>
                  </button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </main>

    <!-- Delete Modal -->
    <div id="deleteModal" class="modal">
      <div class="modal-content">
        <span class="close" id="closeDelete">&times;</span>
        <h2>Confirm Delete</h2>
        <p>Are you sure you want to delete user <strong id="deleteUserName"></strong>?</p>
        <input type="hidden" id="deleteUserId" />
        <button id="cancelDelete" style="padding: 10px 20px; background-color: #6c757d; color: white; border: none; border-radius: 4px; cursor: pointer;">
          Cancel
        </button>
        <button id="confirmDelete" style="padding: 10px 20px; background-color: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer; margin-right: 10px;">
          Delete
        </button>
      </div>
    </div>

    <script src="/scripts/users.js"></script>
  </body>
</html>
